%7 = OpConstant  %6  5
%8 = OpConstant  %6  2
%9 = OpTypeInt 32 0
%10 = OpConstant  %9  5
%11 = OpConstant  %9  2
%4 = OpFunction  %2  None %5
%3 = OpLabel
OpBranch %12
